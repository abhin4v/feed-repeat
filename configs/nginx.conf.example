# Nginx configuration for serving feed-repeat output files
# Place this in /etc/nginx/sites-available/ and symlink to /etc/nginx/sites-enabled/

server {
    listen 80;
    listen [::]:80;
    server_name feeds.example.com;
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name feeds.example.com;

    ssl_certificate /etc/letsencrypt/live/feeds.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/feeds.example.com/privkey.pem;

    location / {
        alias /var/lib/feed-repeat/;
        types {
            application/atom+xml atom;
        }
        default_type application/octet-stream;
        expires 6h;
        add_header Cache-Control "public, max-age=21600";
        add_header Strict-Transport-Security "max-age=31536000" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header Access-Control-Allow-Origin "*" always;
        add_header Access-Control-Allow-Methods "GET, HEAD, OPTIONS" always;
        add_header Access-Control-Allow-Headers "*" always;
    }
}
